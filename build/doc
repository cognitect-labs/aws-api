#!/bin/bash

set -e

echo "Building docs..."
rm -rf ./target/autodoc
./mvnw -ntp -B -Pautodoc clojure:autodoc

echo "Checking out gh-pages branch"
rm -rf gh-pages
git fetch ${AWS_API_REMOTE:-origin} gh-pages
git worktree prune
git worktree add -B gh-pages ./gh-pages ${AWS_API_REMOTE:-origin}/gh-pages

echo "Replacing old gh-pages content with new docs"
cd gh-pages
git rm -rf ./*
cp -Rf ../target/autodoc/* ./
git add -f .
git commit -m "Updating gh-pages with new api docs"
git push -fq ${AWS_API_REMOTE:-origin} gh-pages > /dev/null
cd ..

echo "Cleaning up"
git worktree remove --force gh-pages
